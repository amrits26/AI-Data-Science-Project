# ─── LLM for AI executive summaries ─────────────────────────────────────────
# Priority: Anthropic Claude (preferred) → OpenAI (fallback) → template

# Option 1: Anthropic Claude (recommended — native integration)
ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # default; change to claude-sonnet-4-6 for higher quality

# Option 2: OpenAI (or any OpenAI-compatible endpoint)
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_API_BASE=https://your-llm-endpoint/v1   # optional: custom base URL
# OPENAI_MODEL=gpt-4o-mini                       # default

# ─── Local Ollama for dealership workflows ───────────────────────────────────
DATABASE_URL=sqlite:///./imperial_cars.db
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── API runtime/security ─────────────────────────────────────────────────────
APP_NAME=Imperial Cars AI API
APP_VERSION=1.1.0
APP_ENV=development
CORS_ORIGINS=http://localhost:8501
TRUSTED_HOSTS=localhost,127.0.0.1,.imperialcars.local
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
LOG_LEVEL=INFO
LOG_JSON=1
SALESPERSON_PIN_HASH=  # sha256 of salesperson unlock PIN
# Required: service video approval webhook is disabled until this is set
SERVICE_VIDEO_APPROVAL_SECRET=change-this-shared-secret
# Frontend (Vite) must also provide the matching header value for approval calls
VITE_SERVICE_VIDEO_APPROVAL_SECRET=change-this-shared-secret
# Optional: frontend fallback key injection for protected API calls
VITE_IMPERIAL_API_KEY=
ADMIN_API_SECRET=change-this-admin-secret
PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8081

# Use .env.local for local developer secrets.
# backend/app/main.py and backend/app/core/config.py load .env.local first.
WATCHDOG_BACKEND_PORT=8081

# ─── Local data storage ──────────────────────────────────────────────────────
DATA_DIR=./data
SERVICE_VIDEO_DIR=./data/service_videos
INVENTORY_STALE_HOURS=168
BREAK_EVEN_MONTH=48
IMPORT_SCHEDULER_TASK_NAME=ImperialCars-InventoryImport
KNOWLEDGE_BASE_DIR=./knowledge_base
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FAISS_INDEX_PATH=./knowledge_base/index
MODEL_NAME=llama3
NHTSA_API_ENABLED=true
FUELECONOMY_API_ENABLED=true
CARFAX_API_KEY=
KBB_API_KEY=
CACHE_TTL_HOURS=24
EXTERNAL_API_TIMEOUT_SECONDS=5

# ─── Sales fine-tune routing (optional) ─────────────────────────────────────
USE_SALES_FINETUNE=0
SALES_MODEL_PATH=./models/deepseek_finetuned
SALES_BASE_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-7B
SALES_MODEL_MAX_NEW_TOKENS=220

# ─── Review links used in lifecycle automations ─────────────────────────────
REVIEW_URL_GOOGLE=https://g.page/r/your-dealer/review
REVIEW_URL_CARS=https://www.cars.com/dealers/your-dealer/reviews/
REVIEW_URL_DEALERRATER=https://www.dealerrater.com/dealer/your-dealer-review/

# ─── Telegram bot ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_token_here

# ─── Twilio (SMS, voice calls, voicemail) ────────────────────────────────────
# Get credentials from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567  # Your Twilio phone number (E.164 format)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── SMTP (email notifications) ──────────────────────────────────────────────
# Gmail example (requires app password, not regular password)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=your_email@gmail.com
SMTP_USERNAME=your_email@gmail.com
SMTP_FROM_EMAIL=your_email@gmail.com
