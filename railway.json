{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "gunicorn --workers 3 --worker-class uvicorn.workers.UvicornWorker --bind 0.0.0.0:$PORT backend.app.main:app",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowSeconds": 600
  },
  "environmentVariables": {
    "APP_ENV": "production",
    "PORT": "8000",
    "OLLAMA_MODEL": "deepseek-r1:14b"
  }
}
